    },
    "limite_2_4a": {
      "valore": 2.4,
      "unita": "m",
      "formula": "2.4 * a = 2.4 * 1.0 (Fr <= 0.8)"
    },
    "ys_limited": {
      "valore": 2.4,
      "unita": "m",
      "nota": "Limite 2.4a applicato perche' ys/a=2.543 > 2.4 e Fr=0.326 <= 0.8"
    }
  },
  "toleranza_percentuale": 1.0,
  "note": "Caso in cui il limite HEC-18 per naso arrotondato allineato si applica: ys_CSU/a = 2.543 > 2.4. Lo scalzamento viene cappato a 2.4 m."
